# Revora Discover — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commite o .env.local

# Supabase (Settings → API no painel do projeto)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# Anthropic (https://console.anthropic.com)
VITE_ANTHROPIC_API_KEY=SUA_ANTHROPIC_KEY_AQUI

# Email do super-admin (o seu) — dá acesso ao painel Admin ⚡
VITE_ADMIN_EMAIL=seuemail@exemplo.com
